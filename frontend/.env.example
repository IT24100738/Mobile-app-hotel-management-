# Copy to .env and set your machine's LAN IP so a physical phone can reach the API.
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:5000
EXPO_PUBLIC_API_BASE_URL=

# Optional: extra hostnames to try if the URL above is not set (comma-separated, no protocol).
# Example: EXPO_PUBLIC_API_EXTRA_HOSTS=192.168.1.10,172.28.27.140
EXPO_PUBLIC_API_EXTRA_HOSTS=

# Defaults to 5000 if omitted.
EXPO_PUBLIC_API_PORT=5000
