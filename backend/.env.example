NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.rnsmfin.mongodb.net/hotel_management?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace_with_strong_secret
# Optional: shown in server logs as the URL hint for mobile clients (e.g. http://192.168.1.10:5000)
PUBLIC_API_URL=
# Optional: comma separated frontend origins for browser CORS policy
# Example: CORS_ORIGIN=https://hotel-admin.example.com,https://app.example.com
CORS_ORIGIN=
# Optional API rate limiting controls
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
